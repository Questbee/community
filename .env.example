# ─── Database ────────────────────────────────────────────────────────────────
# Strong random password for the PostgreSQL questbee user.
DB_PASSWORD=changeme_use_a_strong_password

# ─── API ─────────────────────────────────────────────────────────────────────
# Random 32+ character string used to sign JWT tokens.
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme_generate_a_strong_secret_key

# Comma-separated list of origins allowed to make cross-origin requests.
ALLOWED_ORIGINS=http://localhost:3000

# ─── First-run admin account ──────────────────────────────────────────────────
# Credentials for the automatically created admin user on first startup.
# You will be forced to change the password on first login.
ADMIN_EMAIL=admin@questbee.io
ADMIN_PASSWORD=changeme

# ─── Web dashboard ───────────────────────────────────────────────────────────
# Public URL of the API as seen from the browser (not from inside Docker).
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ─── Optional ─────────────────────────────────────────────────────────────────
# Max file upload size in MB (default: 20)
# MAX_UPLOAD_MB=20

# Max submissions per bulk sync request (default: 100)
# SYNC_BATCH_SIZE=100

# Enable MCP server (default: false — Enterprise only)
# MCP_ENABLED=false
